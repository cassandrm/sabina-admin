# Database Configuration
SQLALCHEMY_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/sabina_db

# API Security
API_KEY=your-api-key-here

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Azure Content Understanding (for analyzer list)
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/
AZURE_CONTENT_UNDERSTANDING_KEY=your-key-here
